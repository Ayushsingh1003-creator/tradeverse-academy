{
  "name": "brilliant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');for (const p of ['.next','node_modules/.cache']) { try { fs.rmSync(p,{recursive:true,force:true}); } catch (_) {} }\"",
    "dev": "next dev --turbo",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:seed-leaderboard": "tsx prisma/seed-leaderboard.ts",
    "icons": "node scripts/generate-icons.js",
    "test": "tsx --test src/lib/mergeServerStreak.test.ts src/lib/streak.test.ts",
    "voice:setup": "cd scripts/voice && python -m pip install -r requirements.txt && python download_models.py",
    "voice:server": "cd scripts/voice && python -m pip install -q -r requirements.txt && python server.py"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.55",
    "@ai-sdk/react": "^3.0.174",
    "@base-ui/react": "^1.4.1",
    "@clerk/nextjs": "^6.39.3",
    "@mux/mux-node": "^14.0.1",
    "@mux/mux-player-react": "^3.13.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@stripe/stripe-js": "^9.4.0",
    "@tanstack/react-query": "^5.100.6",
    "@use-gesture/react": "^10.3.1",
    "@vercel/og": "^0.11.1",
    "ai": "^6.0.172",
    "autoprefixer": "^10.5.0",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.39.0",
    "gsap": "^3.15.0",
    "html-to-image": "^1.11.13",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.16.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.14",
    "next-intl": "^4.11.0",
    "next-pwa": "^5.6.0",
    "openai": "^6.35.0",
    "postcss": "^8.5.12",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "shadcn": "^4.6.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^22.1.0",
    "swiper": "^12.1.4",
    "tailwind-merge": "^3.5.0",
    "three": "^0.169.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/web-push": "^3.6.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tailwindcss-rtl": "^0.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts && tsx prisma/seed-library.ts"
  }
}
