generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  clerkUserId    String?   @unique
  name           String
  avatar         String?
  passwordHash   String?
  role           String    @default("user")
  isPremium      Boolean   @default(false)
  premiumUntil   DateTime?
  xp             Int       @default(0)
  level          Int       @default(1)
  streak           Int       @default(0)
  /// Client-local calendar day YYYY-MM-DD for streak continuity (server sync).
  streakLocalDate String?
  /// IANA timezone from client for streak reminder local-day boundaries.
  ianaTimezone    String?
  lastActiveDate  DateTime?
  league          String    @default("bronze")
  createdAt      DateTime  @default(now())
  themePreference String?
  locale          String?
  isCreator       Boolean   @default(false)
  stripeConnectAccountId String?
  country         String?

  progress        LessonProgress[]
  practiceResults PracticeResult[]
  achievements    UserAchievement[]
  accounts        Account[]
  sessions        Session[]
  xpLedger        XpLedger[]
  libraryCourseEnrollments LibraryCourseEnrollment[]
}

model XpLedger {
  id               String   @id @default(cuid())
  userId           String
  amount           Int
  reason           String
  ref              String?
  idempotencyKey   String?  @unique
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model LeagueSeason {
  id          String    @id @default(cuid())
  startsAt    DateTime
  endsAt      DateTime
  finalizedAt DateTime?
  createdAt   DateTime  @default(now())
}

model Course {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  pathId      String
  order       Int
  isFree      Boolean  @default(false)
  thumbnail   String?
  xpReward    Int      @default(100)

  path         LearningPath       @relation(fields: [pathId], references: [id], onDelete: Cascade)
  lessons      Lesson[]
  assignments  CourseAssignment[]
}

model LearningPath {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  level       String
  order       Int
  color       String
  icon        String

  courses Course[]
}

model Lesson {
  id       String @id @default(cuid())
  courseId String
  title    String
  slug     String @unique
  order    Int
  content  String
  xpReward Int    @default(50)
  isFree   Boolean @default(false)

  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]
  practiceSet PracticeSet?
}

model PracticeSet {
  id        String @id @default(cuid())
  lessonId  String @unique
  questions String

  lesson  Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  results PracticeResult[]
}

model LessonProgress {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  completed      Boolean  @default(false)
  score          Int?
  timeSpent      Int?
  nextReviewDate DateTime?
  completedAt    DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model PracticeResult {
  id            String   @id @default(cuid())
  userId        String
  practiceSetId String
  answers       String
  score         Int
  timeSpent     Int
  completedAt   DateTime @default(now())

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  practiceSet PracticeSet @relation(fields: [practiceSetId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String @id @default(cuid())
  title       String
  description String
  icon        String
  condition   String
  xpReward    Int

  users UserAchievement[]
}

model UserAchievement {
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
}

model Subscription {
  id                   String   @id @default(cuid())
  clerkUserId          String   @unique
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  plan                 String   @default("free")
  status               String   @default("inactive")
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String   @unique
  code        String   @unique
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PushSubscription {
  id          String   @id @default(cuid())
  clerkUserId String
  endpoint    String   @unique
  p256dh      String
  auth        String
  createdAt   DateTime @default(now())

  @@index([clerkUserId])
}

model LessonComment {
  id          String               @id @default(cuid())
  lessonSlug  String
  clerkUserId String
  userName    String
  userAvatar  String?
  userLevel   Int
  body        String
  upvotes     Int                  @default(0)
  pinned      Boolean              @default(false)
  createdAt   DateTime             @default(now())
  replies     LessonCommentReply[]
  upvoteRecords CommentUpvote[]

  @@index([lessonSlug])
}

model LessonCommentReply {
  id          String        @id @default(cuid())
  commentId   String
  comment     LessonComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  clerkUserId String
  userName    String
  body        String
  createdAt   DateTime      @default(now())
}

model CommentUpvote {
  clerkUserId String
  commentId   String
  comment     LessonComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([clerkUserId, commentId])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  primaryColor String   @default("#D4A017")
  plan         String   @default("teams")
  seatCount    Int      @default(5)
  stripeId     String?
  createdAt    DateTime @default(now())
  members      OrgMember[]
  assignments  CourseAssignment[]
}

model OrgMember {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  clerkUserId String
  role        String       @default("member")
  joinedAt    DateTime     @default(now())

  @@index([orgId])
  @@index([clerkUserId])
}

model CourseAssignment {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  dueDate   DateTime?
  createdAt DateTime     @default(now())

  @@index([orgId])
}

model LiveSession {
  id           String                @id @default(cuid())
  title        String
  description  String
  instructorId String
  scheduledAt  DateTime
  duration     Int
  maxAttendees Int                   @default(100)
  meetingUrl   String?
  recordingUrl String?
  status       String                @default("scheduled")
  createdAt    DateTime              @default(now())
  attendees    LiveSessionAttendee[]
}

model LiveSessionAttendee {
  sessionId    String
  clerkUserId  String
  registeredAt DateTime @default(now())
  attended     Boolean  @default(false)
  session      LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@id([sessionId, clerkUserId])
}

model SRSCard {
  id             String   @id @default(cuid())
  clerkUserId    String
  lessonSlug     String
  easeFactor     Float    @default(2.5)
  interval       Int      @default(1)
  repetitions    Int      @default(0)
  nextReviewDate DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clerkUserId, lessonSlug])
}

model LessonVideo {
  id            String  @id @default(cuid())
  lessonSlug    String  @unique
  muxAssetId    String
  muxPlaybackId String
  duration      Int
  thumbnail     String?
}

model CreatorApplication {
  id          String   @id @default(cuid())
  clerkUserId String
  name        String
  experience  String
  idea        String
  linkedIn    String?
  twitter     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model MarketplaceCourse {
  id            String   @id @default(cuid())
  creatorClerkId String
  title         String
  slug          String   @unique
  description   String
  priceCents    Int      @default(0)
  coverUrl      String?
  rating        Float    @default(0)
  studentCount  Int      @default(0)
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

// ── Video library (admin-managed) ───────────────────────────────────────────
model LibraryCourse {
  id                   String         @id @default(cuid())
  slug                 String         @unique
  title                String
  description          String
  thumbnailUrl         String
  level                String
  tags                 String
  estimatedDurationMin Int            @default(0)
  published            Boolean        @default(false)
  order                Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  videos LibraryVideo[]
}

/// User enrolled in a library course (by slug; matches DB or static catalog).
model LibraryCourseEnrollment {
  id           String   @id @default(cuid())
  userId       String
  courseSlug   String
  lastVideoId String?
  enrolledAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseSlug])
  @@index([userId])
}

model LibraryVideo {
  id             String   @id @default(cuid())
  courseId       String
  youtubeVideoId String
  title          String
  description    String
  thumbnailUrl   String
  duration       String
  publishedAt    String
  tags           String
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  course LibraryCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

// ── Live cohorts (admin-managed) ────────────────────────────────────────────
model LiveCohort {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  title                String
  subtitle             String
  description          String
  instructorName       String
  instructorBio        String
  instructorAvatarUrl  String?
  startDate            String
  durationWeeks        Int
  schedule             String
  priceLabel           String
  priceAmount          Int
  currency             String   @default("INR")
  stripePriceId        String?
  sampleYoutubeVideoId String
  heroImageUrl         String
  curriculumJson       String
  seats                Int      @default(100)
  seatsLeft            Int      @default(100)
  level                String
  tags                 String
  status               String   @default("draft")
  recordingUrl         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  enrollments LiveCohortEnrollment[]
}

model LiveCohortEnrollment {
  id          String   @id @default(cuid())
  cohortId    String
  clerkUserId String
  email       String
  name        String
  enrolledAt  DateTime @default(now())
  paid        Boolean  @default(false)
  attended    Boolean  @default(false)

  cohort LiveCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  @@unique([cohortId, clerkUserId])
  @@index([cohortId])
}

model CourseConfig {
  id          String   @id @default(cuid())
  slug        String   @unique
  emoji       String   @default("📊")
  accentColor String   @default("#456DFF")
  published   Boolean  @default(true)
  order       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

/// Singleton dashboard top banner (edited in Admin → Site banner). Visual styles stay in `Banner.tsx`.
model SiteBannerConfig {
  id        String   @id @default("default")
  enabled   Boolean  @default(true)
  message   String   @default("Tradeverse update: Track your streak, XP, and lessons from your dashboard.")
  variant   String   @default("rainbow")
  bannerId  String   @default("dashboard-top-banner")
  updatedAt DateTime @updatedAt
}
